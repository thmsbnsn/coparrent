# Frontend (Vite)
# Use the default project URL or a branded custom auth domain like
# https://auth.coparrent.com once Supabase custom domains are active.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SENTRY_DSN=
VITE_VAPID_PUBLIC_KEY=
VITE_PUBLIC_APP_URL=https://coparrent.com
VITE_SUPABASE_PASSKEYS_ENABLED=false
VITE_HCAPTCHA_SITE_KEY=
# Production builds require auth captcha by default. Set to false only for controlled local QA.
VITE_AUTH_CAPTCHA_ENABLED=true

# App URL resolution used by reminders, emails, and deep links
APP_URL=https://coparrent.com
PUBLIC_APP_URL=https://coparrent.com
SITE_URL=https://coparrent.com

# Supabase Edge Function runtime / local tooling
# Keep this on the default project URL unless backend tooling is intentionally
# migrated to the custom domain too.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional staging / sandbox Supabase environment
# Use this for safe migration and multiplayer verification work before production.
SUPABASE_STAGING_PROJECT_ID=
SUPABASE_STAGING_URL=
SUPABASE_STAGING_PUBLISHABLE_KEY=
SUPABASE_STAGING_ANON_KEY=
SUPABASE_STAGING_SERVICE_ROLE_KEY=

# Email and notifications
RESEND_API_KEY=
SUPPORT_EMAIL=support@coparrent.com

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_POWER_PRODUCT_ID=prod_TwwA5VNxPgt62D
STRIPE_POWER_PRICE_ID=price_1Sz2IZHpttmwwVs1H4deOgQe
STRIPE_ALLOWED_PRICE_IDS=price_1Sz2IZHpttmwwVs1H4deOgQe

# Local live-verification helpers
STRIPE_VERIFICATION_BASE_URL=http://127.0.0.1:4174
STRIPE_VERIFICATION_PORTAL_ORIGIN=https://coparrent.com
STRIPE_VERIFICATION_QA_PASSWORD=
AI_RUNTIME_BASE_URL=
AI_RUNTIME_FALLBACK_BASE_URL=http://127.0.0.1:4174
AI_RUNTIME_VERCEL_COOKIES_PATH=
AI_RUNTIME_TESTER_LABEL=Parent A
AI_RUNTIME_HEADLESS=true
PUSH_PWA_BASE_URL=
PUSH_PWA_VERCEL_COOKIES_PATH=
PUSH_PWA_TESTER_LABEL=Parent A
PUSH_PWA_HEADLESS=true
DAILY_CALL_BASE_URL=http://127.0.0.1:4174
DAILY_CALL_CALLER_LABEL=Parent A
DAILY_CALL_CALLEE_LABEL=Parent B
DAILY_CALL_VERCEL_COOKIES_PATH=
DAILY_CALL_HEADLESS=true
PREVIEW_SMOKE_BASE_URL=
PREVIEW_SMOKE_VERCEL_COOKIES_PATH=
PREVIEW_SMOKE_TESTER_LABEL=Parent A
PREVIEW_SMOKE_HEADLESS=true

# Family game multiplayer verification
# These can point at staging explicitly without changing the active app runtime.
VERIFY_FAMILY_GAME_SUPABASE_URL=
VERIFY_FAMILY_GAME_SUPABASE_ANON_KEY=
VERIFY_FAMILY_GAME_FAMILY_ID=
VERIFY_FAMILY_GAME_HOST_EMAIL=
VERIFY_FAMILY_GAME_HOST_PASSWORD=
VERIFY_FAMILY_GAME_GUEST_EMAIL=
VERIFY_FAMILY_GAME_GUEST_PASSWORD=

# AI providers
OPENROUTER_API_KEY=

# Daily calling
DAILY_API_KEY=
DAILY_CO_API_KEY=
DAILY_DOMAIN=
DAILY_WEBHOOK_SECRET=

# Immutable court-record export storage
AWS_REGION=
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Legacy local/dev compatibility alias. Prefer AWS_ACCESS_KEY_ID.
AWS_ACCESS_KEY=

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Origin controls
# Keep this list narrow. Preview hosts should be added via ALLOWED_ORIGIN_PATTERNS.
ALLOWED_ORIGINS=https://coparrent.com,https://www.coparrent.com,https://coparrent.vercel.app
ALLOWED_ORIGIN_PATTERNS=https://coparrent-*.vercel.app
ALLOW_LOCALHOST_ORIGINS=false

# Optional auth hardening
HCAPTCHA_SECRET_KEY=
